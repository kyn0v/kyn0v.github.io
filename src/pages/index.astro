      </a>
      <a href="https://space.bilibili.com/12334638" target="_blank" aria-label="哔哩哔哩" title="哔哩哔哩" style="--brand:#FB7299">
        <svg viewBox="0 0 24 24" role="img"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373Z"/></svg>
      </a>
      <a href="https://www.xiaoyuzhoufm.com/podcast/67dff6130ff066afdbb00285" target="_blank" aria-label="小宇宙播客" title="小宇宙播客">
        <img src={`${base}/assets/xiaoyuzhou.png`} alt="小宇宙播客" />
      </a>
      <a href="https://y.music.163.com/m/user?id=57757556" target="_blank" aria-label="网易云音乐" title="网易云音乐" style="--brand:#C20C0C">
        <svg viewBox="0 0 24 24" role="img"><path d="M13.046 9.388a3.919 3.919 0 0 0-.66.19c-.809.312-1.447.991-1.666 1.775a2.269 2.269 0 0 0-.074.81c.048.546.333 1.05.764 1.35a1.483 1.483 0 0 0 2.01-.286c.406-.531.355-1.183.24-1.636-.098-.387-.22-.816-.345-1.249a64.76 64.76 0 0 1-.269-.954zm-.82 10.07c-3.984 0-7.224-3.24-7.224-7.223 0-.98.226-3.02 1.884-4.822A7.188 7.188 0 0 1 9.502 5.6a.792.792 0 1 1 .587 1.472 5.619 5.619 0 0 0-2.795 2.462 5.538 5.538 0 0 0-.707 2.7 5.645 5.645 0 0 0 5.638 5.638c1.844 0 3.627-.953 4.542-2.428 1.042-1.68.772-3.931-.627-5.238a3.299 3.299 0 0 0-1.437-.777c.172.589.334 1.18.494 1.772.284 1.12.1 2.181-.519 2.989-.39.51-.956.888-1.592 1.064a3.038 3.038 0 0 1-2.58-.44 3.45 3.45 0 0 1-1.44-2.514c-.04-.467.002-.93.128-1.376.35-1.256 1.356-2.339 2.622-2.826a5.5 5.5 0 0 1 .823-.246l-.134-.505c-.37-1.371.25-2.579 1.547-3.007.329-.109.68-.145 1.025-.105.792.09 1.476.592 1.709 1.023.258.507-.096 1.153-.706 1.153a.788.788 0 0 1-.54-.213c-.088-.08-.163-.174-.259-.247a.825.825 0 0 0-.632-.166.807.807 0 0 0-.634.551c-.056.191-.031.406.02.595.07.256.159.597.217.82 1.11.098 2.162.54 2.97 1.296 1.974 1.844 2.35 4.886.892 7.233-1.197 1.93-3.509 3.177-5.889 3.177zM0 12c0 6.627 5.373 12 12 12s12-5.373 12-12S18.627 0 12 0 0 5.373 0 12Z"/></svg>
      </a>
      <a href="https://www.douban.com/people/kynov/" target="_blank" aria-label="豆瓣" title="豆瓣" style="--brand:#2D963D">
        <svg viewBox="0 0 24 24" role="img"><path d="M.51 3.06h22.98V.755H.51V3.06Zm20.976 2.537v9.608h-2.137l-1.669 5.76H24v2.28H0v-2.28h6.32l-1.67-5.76H2.515V5.597h18.972Zm-5.066 9.608H7.58l1.67 5.76h5.501l1.67-5.76ZM18.367 7.9H5.634v5.025h12.733V7.9Z"/></svg>
      </a>
      <a id="email-link" href="#" data-user="kynov" data-domain="outlook.com" aria-label="Email" title="Email">
        <svg viewBox="0 0 24 24" role="img"><path d="M1.5 4.5h21A1.5 1.5 0 0 1 24 6v12a1.5 1.5 0 0 1-1.5 1.5h-21A1.5 1.5 0 0 1 0 18V6a1.5 1.5 0 0 1 1.5-1.5zm.6 1.8L12 12.9l9.9-6.6H2.1zM22.2 7.8l-9.66 6.44a.9.9 0 0 1-1.08 0L1.8 7.8V18h20.4V7.8z"/></svg>
      </a>
    </nav>

    <!-- Tabs -->
    <nav class="tabs" id="tabs">
      <button class="tab active" data-tab="home">主页</button>
      <button class="tab" data-tab="timeline">时间线</button>
    </nav>

    <!-- Home panel: pinned -->
    <section class="tab-panel active" id="panel-home">
      <div class="pinned-grid" id="pinned">
        {pinned.length === 0 && <div class="empty">还没有 Pin 任何内容 ~</div>}
        {pinned.map((e) => {
          const meta = TYPE_META[e.type];
          return (
            <a href={e.link} target={e.link.startsWith('http') ? '_blank' : null}>
              <div class="pin-card" style={`--type-color:${meta.color}`}>
                <div class="pin-top">
                  <span class="badge" title={meta.label}>{meta.emoji}</span>
                  <span class="pin-date">{e.date}</span>
                </div>
                <h3>{e.title}</h3>
                {e.desc && <p>{e.desc}</p>}
                <span class="link-hint">查看 →</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Timeline panel -->
    <section class="tab-panel" id="panel-timeline">
      <div class="section-label filter-toggle" id="filterToggle" role="button" tabindex="0" aria-expanded="true" aria-controls="filters">
        分类<span class="caret">▾</span>
      </div>
      <div class="filters" id="filters">
        <span class="chip active" data-type="all">全部</span>
        {CATS.map(([type, label]) => (
          <span class="chip" data-type={type}><span class="dot" style={`background:var(--c-${type})`}></span>{label}</span>
        ))}
      </div>
      <div class="timeline" id="timeline">
        {all.map((e) => {
          const meta = TYPE_META[e.type];
          return (
            <div class="entry" data-type={e.type} style={`--type-color:${meta.color}`}>
              <div class="date">{e.date}</div>
              <a href={e.link} target={e.link.startsWith('http') ? '_blank' : null}>
                <div class="card">
                  <span class="badge" title={meta.label}>{meta.emoji}</span>
                  <h3>{e.title}</h3>
                  {e.desc && <p>{e.desc}</p>}
                  <span class="link-hint">查看 →</span>
                </div>
              </a>
            </div>
          );
        })}
      </div>
      <div class="empty" id="timeline-empty" style="display:none">这个分类暂时还没有作品 ~</div>
    </section>
  </div>

  <script is:inline>
    // Tab 切换
    (function () {
      const tabs = document.getElementById("tabs");
      tabs.addEventListener("click", (ev) => {
        const tab = ev.target.closest(".tab");
        if (!tab) return;
        const name = tab.dataset.tab;
        document.querySelectorAll(".tab").forEach((t) => t.classList.toggle("active", t === tab));
        document.querySelectorAll(".tab-panel").forEach((p) => {
          p.classList.toggle("active", p.id === "panel-" + name);
        });
      });
    })();

    // 分类筛选（显示/隐藏服务端渲染的条目）
    (function () {
      let current = "all";
      const filters = document.getElementById("filters");
      const entries = Array.from(document.querySelectorAll("#timeline .entry"));
      const emptyEl = document.getElementById("timeline-empty");
      function apply() {
        let visible = 0;
        entries.forEach((el) => {
          const show = current === "all" || el.dataset.type === current;
          el.style.display = show ? "" : "none";
          if (show) visible++;
        });
        emptyEl.style.display = visible === 0 ? "" : "none";
      }
      filters.addEventListener("click", (ev) => {
        const chip = ev.target.closest(".chip");
        if (!chip) return;
        document.querySelectorAll(".chip").forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
        current = chip.dataset.type;
        apply();
      });
    })();

    // 分类折叠
    (function () {
      const toggle = document.getElementById("filterToggle");
      const filters = document.getElementById("filters");
      const KEY = "filters-collapsed";
      function setCollapsed(collapsed) {
        filters.classList.toggle("collapsed", collapsed);
        toggle.setAttribute("aria-expanded", String(!collapsed));
        localStorage.setItem(KEY, collapsed ? "1" : "0");
      }
      setCollapsed(localStorage.getItem(KEY) === "1");
      toggle.addEventListener("click", () => setCollapsed(!filters.classList.contains("collapsed")));
      toggle.addEventListener("keydown", (ev) => {
        if (ev.key === "Enter" || ev.key === " ") {
          ev.preventDefault();
          setCollapsed(!filters.classList.contains("collapsed"));
        }
      });
    })();
  </script>
</Base>
